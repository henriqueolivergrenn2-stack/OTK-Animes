{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "otk-animes",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}