<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-logo">
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="32" height="32" rx="8" fill="url(#fgrad)"/>
        <path d="M12 10L22 16L12 22V10Z" fill="white"/>
        <defs><linearGradient id="fgrad" x1="0" y1="0" x2="32" y2="32"><stop offset="0%" stop-color="#ff6b35"/><stop offset="100%" stop-color="#ff8c42"/></linearGradient></defs>
      </svg>
      <span>OTK ANIMES</span>
    </div>
    <p class="footer-text">Assista aos melhores animes online.</p>
    <div class="footer-links">
      <a href="/">Inicio</a>
      <a href="/catalogo">Catalogo</a>
      <% if (user) { %>
        <a href="/profile">Perfil</a>
        <% if (user.role === 'admin') { %>
          <a href="/admin">Admin</a>
        <% } %>
      <% } else { %>
        <a href="/login">Login</a>
        <a href="/register">Cadastro</a>
      <% } %>
    </div>
    <p class="footer-copy">&copy; 2026 OTK ANIMES. Todos os direitos reservados.</p>
  </div>
</footer>

