<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('partials/head') %>
  <style>
    /* ============================================
       PLAYER VIDEO - VERSÃO OTIMIZADA
       Compatível: Android, iOS, PC
       ============================================ */

    :root {
      --player-bg: #000;
      --controls-bg: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.6) 60%, transparent 100%);
      --accent-color: #ff4757;
      --progress-height: 4px;
      --progress-height-hover: 6px;
      --btn-size: 40px;
      --btn-size-mobile: 36px;
      --transition-fast: 0.15s ease;
      --transition-normal: 0.25s ease;
      --border-radius: 12px;
      --border-radius-mobile: 8px;
    }

    /* Container principal do player */
    .player-wrapper {
      position: relative;
      width: 100%;
      background: var(--player-bg);
      border-radius: var(--border-radius);
      overflow: hidden;
      aspect-ratio: 16 / 9;
      cursor: pointer;
      user-select: none;
      -webkit-user-select: none;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
      box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

    .player-wrapper video {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }

    /* Loading spinner */
    .video-loading {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0,0,0,0.3);
      z-index: 5;
      transition: opacity var(--transition-fast);
    }
    .video-loading.hidden { opacity: 0; pointer-events: none; }

    .spinner {
      width: 50px;
      height: 50px;
      border: 3px solid rgba(255,255,255,0.2);
      border-top-color: var(--accent-color);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Botão play central */
    .center-play {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 10;
      transition: opacity var(--transition-fast), transform var(--transition-fast);
    }
    .center-play.hidden { opacity: 0; pointer-events: none; transform: scale(0.8); }

    .center-play-btn {
      width: 80px;
      height: 80px;
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform var(--transition-fast), background var(--transition-fast);
      border: 2px solid rgba(255,255,255,0.2);
    }
    .center-play-btn:hover { transform: scale(1.1); background: rgba(0,0,0,0.8); }
    .center-play-btn svg { width: 32px; height: 32px; color: #fff; margin-left: 4px; }

    /* Gesture zones para double-tap */
    .gesture-zone {
      position: absolute;
      top: 0;
      bottom: 0;
      width: 35%;
      z-index: 8;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
    }
    .gesture-left { left: 0; }
    .gesture-right { right: 0; }

    .seek-hint {
      background: rgba(0,0,0,0.7);
      color: #fff;
      padding: 12px 20px;
      border-radius: 8px;
      font-size: 18px;
      font-weight: 600;
      opacity: 0;
      transform: scale(0.8);
      transition: opacity 0.3s ease, transform 0.3s ease;
      pointer-events: none;
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }
    .seek-hint.show { opacity: 1; transform: scale(1); }

    /* Controles */
    .video-controls {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 40px 16px 12px;
      background: var(--controls-bg);
      z-index: 20;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity var(--transition-normal), transform var(--transition-normal);
      pointer-events: none;
    }
    .player-wrapper.show-controls .video-controls {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    /* Barra de progresso */
    .video-progress-container {
      position: relative;
      width: 100%;
      height: var(--progress-height);
      margin-bottom: 8px;
      cursor: pointer;
      border-radius: 2px;
      background: rgba(255,255,255,0.2);
      transition: height var(--transition-fast);
    }
    .video-progress-container:hover { height: var(--progress-height-hover); }

    .video-progress-fill {
      height: 100%;
      background: var(--accent-color);
      border-radius: 2px;
      width: 0%;
      position: relative;
      transition: width 0.1s linear;
    }
    .video-progress-fill::after {
      content: '';
      position: absolute;
      right: -6px;
      top: 50%;
      transform: translateY(-50%) scale(0);
      width: 12px;
      height: 12px;
      background: #fff;
      border-radius: 50%;
      box-shadow: 0 0 8px rgba(0,0,0,0.5);
      transition: transform var(--transition-fast);
    }
    .video-progress-container:hover .video-progress-fill::after { transform: translateY(-50%) scale(1); }

    /* Tooltip de tempo ao arrastar */
    .progress-tooltip {
      position: absolute;
      top: -35px;
      background: rgba(0,0,0,0.9);
      color: #fff;
      padding: 4px 10px;
      border-radius: 4px;
      font-size: 12px;
      font-weight: 500;
      opacity: 0;
      transform: translateX(-50%) translateY(5px);
      transition: opacity var(--transition-fast), transform var(--transition-fast);
      pointer-events: none;
      white-space: nowrap;
    }
    .video-progress-container:hover .progress-tooltip { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* Botões de controle */
    .video-buttons {
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .vbtn {
      width: var(--btn-size);
      height: var(--btn-size);
      display: flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      border: none;
      color: #fff;
      cursor: pointer;
      border-radius: 8px;
      transition: background var(--transition-fast), transform var(--transition-fast);
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
    }
    .vbtn:hover { background: rgba(255,255,255,0.15); transform: scale(1.1); }
    .vbtn:active { transform: scale(0.95); }
    .vbtn svg { width: 22px; height: 22px; }

    .vtime {
      color: #fff;
      font-size: 13px;
      font-weight: 500;
      font-variant-numeric: tabular-nums;
      margin: 0 8px;
      min-width: 100px;
      text-shadow: 0 1px 2px rgba(0,0,0,0.5);
    }

    .v-spacer { flex: 1; }

    /* Volume slider (aparece no hover do botão mute) */
    .volume-container {
      position: relative;
      display: flex;
      align-items: center;
    }
    .volume-slider {
      width: 0;
      overflow: hidden;
      transition: width var(--transition-fast);
      display: flex;
      align-items: center;
    }
    .volume-container:hover .volume-slider { width: 80px; }
    .volume-slider input[type="range"] {
      width: 70px;
      height: 4px;
      -webkit-appearance: none;
      appearance: none;
      background: rgba(255,255,255,0.3);
      border-radius: 2px;
      outline: none;
      margin-left: 8px;
    }
    .volume-slider input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 12px;
      height: 12px;
      background: #fff;
      border-radius: 50%;
      cursor: pointer;
    }

    /* Velocidade de reprodução */
    .speed-btn {
      font-size: 12px;
      font-weight: 600;
      padding: 0 8px;
      width: auto;
      min-width: 40px;
    }

    /* Menu de velocidade */
    .speed-menu {
      position: absolute;
      bottom: 50px;
      right: 80px;
      background: rgba(0,0,0,0.9);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-radius: 8px;
      padding: 8px 0;
      opacity: 0;
      transform: translateY(10px) scale(0.95);
      transition: all var(--transition-fast);
      pointer-events: none;
      z-index: 30;
      min-width: 100px;
    }
    .speed-menu.show {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: auto;
    }
    .speed-option {
      padding: 8px 16px;
      color: #fff;
      font-size: 13px;
      cursor: pointer;
      transition: background var(--transition-fast);
      text-align: center;
    }
    .speed-option:hover { background: rgba(255,255,255,0.1); }
    .speed-option.active { color: var(--accent-color); font-weight: 600; }

    /* Picture in Picture */
    .pip-btn svg { width: 20px; height: 20px; }

    /* Buffer indicator */
    .buffer-indicator {
      position: absolute;
      top: 0;
      left: 0;
      height: 3px;
      background: rgba(255,255,255,0.3);
      z-index: 6;
      width: 0%;
      transition: width 0.3s ease;
    }

    /* Info overlay (título do episódio) */
    .player-info-overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      padding: 16px;
      background: linear-gradient(to bottom, rgba(0,0,0,0.7) 0%, transparent 100%);
      z-index: 15;
      opacity: 0;
      transform: translateY(-10px);
      transition: opacity var(--transition-normal), transform var(--transition-normal);
      pointer-events: none;
    }
    .player-wrapper.show-controls .player-info-overlay {
      opacity: 1;
      transform: translateY(0);
    }
    .player-info-overlay h3 {
      color: #fff;
      font-size: 14px;
      font-weight: 600;
      margin: 0;
      text-shadow: 0 1px 2px rgba(0,0,0,0.5);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .player-info-overlay p {
      color: rgba(255,255,255,0.8);
      font-size: 12px;
      margin: 4px 0 0;
    }

    /* Skip intro button */
    .skip-intro {
      position: absolute;
      bottom: 80px;
      right: 16px;
      background: rgba(0,0,0,0.8);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      color: #fff;
      padding: 10px 20px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      z-index: 15;
      opacity: 0;
      transform: translateY(20px);
      transition: all var(--transition-normal);
      border: 1px solid rgba(255,255,255,0.1);
      pointer-events: none;
    }
    .skip-intro.show {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
    .skip-intro:hover { background: rgba(0,0,0,0.9); border-color: var(--accent-color); }

    /* Next episode countdown */
    .next-episode-countdown {
      position: absolute;
      bottom: 80px;
      right: 16px;
      background: rgba(0,0,0,0.85);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      color: #fff;
      padding: 12px 20px;
      border-radius: 12px;
      font-size: 13px;
      z-index: 15;
      opacity: 0;
      transform: translateY(20px);
      transition: all var(--transition-normal);
      display: flex;
      align-items: center;
      gap: 12px;
      pointer-events: none;
    }
    .next-episode-countdown.show {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
    .countdown-ring {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      border: 3px solid rgba(255,255,255,0.2);
      border-top-color: var(--accent-color);
      animation: spin 1s linear infinite;
    }

    /* ============================================
       RESPONSIVIDADE - MOBILE
       ============================================ */
    @media (max-width: 768px) {
      .player-wrapper {
        border-radius: var(--border-radius-mobile);
        aspect-ratio: 16 / 9;
      }

      .watch-layout { padding-top: 4px !important; }

      .center-play-btn {
        width: 60px;
        height: 60px;
      }
      .center-play-btn svg { width: 24px; height: 24px; }

      .video-controls { padding: 30px 12px 10px; }

      .vbtn {
        width: var(--btn-size-mobile);
        height: var(--btn-size-mobile);
      }
      .vbtn svg { width: 20px; height: 20px; }

      .vtime { font-size: 12px; min-width: 85px; margin: 0 4px; }

      .gesture-zone { width: 40%; }
      .seek-hint { padding: 8px 14px; font-size: 14px; }

      .speed-menu { right: 60px; bottom: 45px; }

      .player-info-overlay h3 { font-size: 12px; }
      .player-info-overlay p { font-size: 11px; }

      .skip-intro,
      .next-episode-countdown {
        bottom: 65px;
        right: 12px;
        padding: 8px 14px;
        font-size: 12px;
      }
    }

    /* iOS específico */
    @supports (-webkit-touch-callout: none) {
      .player-wrapper {
        -webkit-touch-callout: none;
      }
      video::-webkit-media-controls {
        display: none !important;
      }
      video::-webkit-media-controls-enclosure {
        display: none !important;
      }
    }

    /* Android/Chrome específico */
    video::-webkit-media-controls-panel {
      display: none !important;
    }
    video::-webkit-media-controls-play-button {
      display: none !important;
    }
    video::-webkit-media-controls-start-playback-button {
      display: none !important;
    }

    /* Fullscreen */
    .player-wrapper:fullscreen {
      border-radius: 0;
      aspect-ratio: auto;
      height: 100vh;
    }
    .player-wrapper:-webkit-full-screen {
      border-radius: 0;
      aspect-ratio: auto;
      height: 100vh;
    }
    .player-wrapper:-moz-full-screen {
      border-radius: 0;
      aspect-ratio: auto;
      height: 100vh;
    }

    /* Estado de buffering */
    .player-wrapper.buffering .spinner {
      display: block !important;
    }

    /* Animação de pulse no botão play */
    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }
    .center-play-btn.pulse {
      animation: pulse 2s ease-in-out infinite;
    }

    /* Touch feedback */
    .touch-feedback {
      position: absolute;
      width: 60px;
      height: 60px;
      background: rgba(255,255,255,0.2);
      border-radius: 50%;
      pointer-events: none;
      transform: scale(0);
      animation: ripple 0.6s ease-out forwards;
      z-index: 25;
    }
    @keyframes ripple {
      to { transform: scale(2); opacity: 0; }
    }
  </style>
</head>
<body>
<%- include('partials/nav') %>

<div class="container">
  <div class="watch-layout" style="padding-top:8px">

    <!-- Player -->
    <div>
      <div class="player-wrapper" id="pwrap">
        <div class="video-loading" id="vloading"><div class="spinner"></div></div>

        <div class="center-play" id="centerPlay">
          <div class="center-play-btn" id="centerPlayBtn">
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </div>
        </div>

        <!-- Buffer indicator -->
        <div class="buffer-indicator" id="bufferIndicator"></div>

        <!-- Info overlay -->
        <div class="player-info-overlay" id="infoOverlay">
          <h3><%= anime.title || '' %> - EP <%= episode.number || '?' %></h3>
          <p><%= episode.title || ('Episodio ' + episode.number) %></p>
        </div>

        <!-- Gesture zones -->
        <div class="gesture-zone gesture-left" id="gestureLeft">
          <span class="seek-hint" id="seekBack">-10s</span>
        </div>
        <div class="gesture-zone gesture-right" id="gestureRight">
          <span class="seek-hint" id="seekFwd">+10s</span>
        </div>

        <!-- Skip intro button -->
        <div class="skip-intro" id="skipIntro" onclick="event.stopPropagation();skipIntro()">
          Pular Intro
        </div>

        <!-- Next episode countdown -->
        <div class="next-episode-countdown" id="nextCountdown">
          <div class="countdown-ring"></div>
          <span>Próximo episódio em <span id="countdownNum">5</span>s</span>
        </div>

        <video
          id="video"
          src="<%= episode.videoUrl || '' %>"
          preload="metadata"
          playsinline
          webkit-playsinline
          x5-playsinline
          x5-video-player-type="h5"
          x5-video-player-fullscreen="false"
          x5-video-orientation="portrait"
          disablepictureinpicture="false"
        ></video>

        <div class="video-controls" id="vcontrols">
          <div class="video-progress-container" id="vprogress">
            <div class="video-progress-fill" id="vfill"></div>
            <div class="progress-tooltip" id="progressTooltip">0:00</div>
          </div>
          <div class="video-buttons">
            <button class="vbtn" id="playBtn" title="Play/Pause (K)">
              <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </button>
            <span class="vtime" id="vtime">0:00 / 0:00</span>

            <div class="v-spacer"></div>

            <!-- Volume com slider -->
            <div class="volume-container">
              <button class="vbtn" id="muteBtn" title="Mute/Unmute (M)">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
              </button>
              <div class="volume-slider">
                <input type="range" id="volumeSlider" min="0" max="1" step="0.05" value="1">
              </div>
            </div>

            <!-- Velocidade -->
            <button class="vbtn speed-btn" id="speedBtn" title="Velocidade">1x</button>
            <div class="speed-menu" id="speedMenu">
              <div class="speed-option" data-speed="0.5">0.5x</div>
              <div class="speed-option" data-speed="0.75">0.75x</div>
              <div class="speed-option active" data-speed="1">1x</div>
              <div class="speed-option" data-speed="1.25">1.25x</div>
              <div class="speed-option" data-speed="1.5">1.5x</div>
              <div class="speed-option" data-speed="2">2x</div>
            </div>

            <!-- Picture in Picture -->
            <button class="vbtn pip-btn" id="pipBtn" title="Picture in Picture">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            </button>

            <% if (episode.videoUrl) { %>
            <a class="vbtn" href="<%= episode.videoUrl %>" download title="Download" onclick="event.stopPropagation()">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            </a>
            <% } %>

            <button class="vbtn" id="fullscreenBtn" title="Fullscreen (F)">
              <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>
            </button>
          </div>
        </div>
      </div>

      <div class="player-info">
        <h1><%= anime.title || '' %> - EP <%= episode.number || '?' %></h1>
        <p><%= episode.title || ('Episodio ' + episode.number) %></p>
      </div>

      <div class="player-nav">
        <% if (prevEpisode) { %>
        <a href="/watch/<%= anime.id %>/<%= prevEpisode.id %>" class="btn btn-secondary btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          EP <%= prevEpisode.number %>
        </a>
        <% } %>
        <a href="/anime/<%= anime.id %>" class="btn btn-secondary btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          Lista
        </a>
        <% if (nextEpisode) { %>
        <a href="/watch/<%= anime.id %>/<%= nextEpisode.id %>" class="btn btn-primary btn-sm">
          EP <%= nextEpisode.number %>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
        <% } %>
      </div>

      <% if (related && related.length > 0) { %>
      <section class="content-section">
        <div class="section-header">
          <h2 class="section-title" style="font-size:16px">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            Relacionados
          </h2>
        </div>
        <div class="anime-grid">
          <% related.forEach(function(r) { %>
          <div class="anime-card" onclick="location.href='/anime/<%= r.id %>'">
            <div class="anime-card-cover" style="aspect-ratio:3/4">
              <img src="<%= r.cover || '' %>" alt="<%= r.title || '' %>">
            </div>
            <div class="anime-card-info" style="padding:8px">
              <div class="anime-card-title" style="font-size:12px"><%= r.title || '' %></div>
            </div>
          </div>
          <% }) %>
        </div>
      </section>
      <% } %>
    </div>

    <!-- Sidebar -->
    <% if (episodes && episodes.length > 0) { %>
    <div class="sidebar">
      <div class="sidebar-header"><%= anime.title || '' %> - <%= episodes.length %> EPs</div>
      <div class="sidebar-list">
        <% episodes.forEach(function(ep) { %>
        <div class="sidebar-ep <%= ep.id === episode.id ? 'active' : '' %>" onclick="location.href='/watch/<%= anime.id %>/<%= ep.id %>'">
          <div class="sidebar-ep-thumb">
            <img src="<%= ep.thumbnail || anime.cover || '' %>" alt="">
          </div>
          <div class="sidebar-ep-info">
            <div class="sidebar-ep-num">EP <%= ep.number || '?' %></div>
            <div class="sidebar-ep-title"><%= ep.title || ('Episodio ' + ep.number) %></div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>

  </div>
</div>

<%- include('partials/footer') %>

<script>
(function() {
  'use strict';

  // ============================================
  // ELEMENTOS DO DOM
  // ============================================
  var video = document.getElementById('video');
  var pwrap = document.getElementById('pwrap');
  var vfill = document.getElementById('vfill');
  var vtime = document.getElementById('vtime');
  var playBtn = document.getElementById('playBtn');
  var muteBtn = document.getElementById('muteBtn');
  var centerPlay = document.getElementById('centerPlay');
  var centerPlayBtn = document.getElementById('centerPlayBtn');
  var vcontrols = document.getElementById('vcontrols');
  var vprogress = document.getElementById('vprogress');
  var progressTooltip = document.getElementById('progressTooltip');
  var bufferIndicator = document.getElementById('bufferIndicator');
  var fullscreenBtn = document.getElementById('fullscreenBtn');
  var speedBtn = document.getElementById('speedBtn');
  var speedMenu = document.getElementById('speedMenu');
  var pipBtn = document.getElementById('pipBtn');
  var volumeSlider = document.getElementById('volumeSlider');
  var skipIntroBtn = document.getElementById('skipIntro');
  var nextCountdown = document.getElementById('nextCountdown');
  var countdownNum = document.getElementById('countdownNum');

  // ============================================
  // ESTADO DO PLAYER
  // ============================================
  var controlsVisible = false;
  var controlsTimer;
  var lastTap = 0;
  var tapCount = 0;
  var tapTimer;
  var isDragging = false;
  var wasPlayingBeforeDrag = false;
  var isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
  var isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
  var currentSpeed = 1;
  var introSkipped = false;
  var countdownInterval;

  // Tempo de intro padrão (pode ser ajustado por anime)
  var introStart = 0;
  var introEnd = 90; // 1min30s padrão para skip intro

  // ============================================
  // UTILITÁRIOS
  // ============================================
  function fmt(t) {
    if (!t || isNaN(t)) return '0:00';
    var h = Math.floor(t / 3600);
    var m = Math.floor((t % 3600) / 60);
    var s = Math.floor(t % 60);
    if (h > 0) return h + ':' + (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
    return m + ':' + (s < 10 ? '0' : '') + s;
  }

  function getStorageKey() {
    return 'ns_prog_' + location.pathname.split('/').slice(2).join('_');
  }

  function createRipple(x, y) {
    var ripple = document.createElement('div');
    ripple.className = 'touch-feedback';
    ripple.style.left = (x - 30) + 'px';
    ripple.style.top = (y - 30) + 'px';
    pwrap.appendChild(ripple);
    setTimeout(function() { ripple.remove(); }, 600);
  }

  // ============================================
  // INICIALIZAÇÃO
  // ============================================
  window.initPlayer = function() {
    var saved = localStorage.getItem(getStorageKey());
    if (saved) {
      var t = parseFloat(saved);
      if (t > 3 && t < video.duration - 10) {
        video.currentTime = t;
      }
    }

    // Inicializa volume
    video.volume = parseFloat(localStorage.getItem('ns_volume') || '1');
    volumeSlider.value = video.volume;

    // Inicializa velocidade
    var savedSpeed = localStorage.getItem('ns_speed');
    if (savedSpeed) {
      currentSpeed = parseFloat(savedSpeed);
      video.playbackRate = currentSpeed;
      speedBtn.textContent = currentSpeed + 'x';
      updateSpeedMenu();
    }

    // Esconde loading
    document.getElementById('vloading').classList.add('hidden');
  };

  // ============================================
  // CONTROLES DE PLAY/PAUSE
  // ============================================
  window.togglePlay = function() {
    if (!video) return;
    if (video.paused || video.ended) {
      var playPromise = video.play();
      if (playPromise !== undefined) {
        playPromise.then(function() {
          updatePlayButton(true);
          showControls();
        }).catch(function(err) {
          console.warn('Play failed:', err);
        });
      }
    } else {
      video.pause();
      updatePlayButton(false);
      showControls();
    }
  };

  function updatePlayButton(playing) {
    if (playing) {
      centerPlay.classList.add('hidden');
      playBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>';
      playBtn.title = 'Pause (K)';
    } else {
      centerPlay.classList.remove('hidden');
      playBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';
      playBtn.title = 'Play (K)';
    }
  }

  // ============================================
  // CONTROLES DE VOLUME
  // ============================================
  window.toggleMute = function() {
    if (!video) return;
    video.muted = !video.muted;
    updateMuteButton();
    localStorage.setItem('ns_muted', video.muted);
  };

  function updateMuteButton() {
    if (video.muted || video.volume === 0) {
      muteBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>';
      muteBtn.title = 'Unmute (M)';
      volumeSlider.value = 0;
    } else {
      muteBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>';
      muteBtn.title = 'Mute (M)';
      volumeSlider.value = video.volume;
    }
  }

  volumeSlider.addEventListener('input', function() {
    video.volume = parseFloat(this.value);
    video.muted = false;
    localStorage.setItem('ns_volume', video.volume);
    updateMuteButton();
  });

  // ============================================
  // FULLSCREEN
  // ============================================
  window.toggleFullscreen = function() {
    if (!pwrap) return;
    try {
      if (document.fullscreenElement || document.webkitFullscreenElement || document.mozFullScreenElement) {
        if (document.exitFullscreen) document.exitFullscreen();
        else if (document.webkitExitFullscreen) document.webkitExitFullscreen();
        else if (document.mozCancelFullScreen) document.mozCancelFullScreen();
      } else {
        if (pwrap.requestFullscreen) pwrap.requestFullscreen();
        else if (pwrap.webkitRequestFullscreen) pwrap.webkitRequestFullscreen();
        else if (pwrap.mozRequestFullScreen) pwrap.mozRequestFullScreen();
      }
    } catch(e) {
      console.warn('Fullscreen error:', e);
    }
  };

  function updateFullscreenButton() {
    var isFullscreen = !!(document.fullscreenElement || document.webkitFullscreenElement || document.mozFullScreenElement);
    if (isFullscreen) {
      fullscreenBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z"/></svg>';
      fullscreenBtn.title = 'Exit Fullscreen (F)';
    } else {
      fullscreenBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>';
      fullscreenBtn.title = 'Fullscreen (F)';
    }
  }

  document.addEventListener('fullscreenchange', updateFullscreenButton);
  document.addEventListener('webkitfullscreenchange', updateFullscreenButton);
  document.addEventListener('mozfullscreenchange', updateFullscreenButton);

  // ============================================
  // SEEK / PROGRESSO
  // ============================================
  window.seekTo = function(e) {
    if (!video || !video.duration) return;
    var rect = vprogress.getBoundingClientRect();
    var pos = (e.clientX - rect.left) / rect.width;
    pos = Math.max(0, Math.min(1, pos));
    video.currentTime = pos * video.duration;
    showControls();
  };

  window.seekRel = function(sec) {
    if (!video || !video.duration) return;
    video.currentTime = Math.max(0, Math.min(video.duration, video.currentTime + sec));
    var hint = sec > 0 ? document.getElementById('seekFwd') : document.getElementById('seekBack');
    if (hint) {
      hint.textContent = (sec > 0 ? '+' : '') + sec + 's';
      hint.classList.add('show');
      setTimeout(function() { hint.classList.remove('show'); }, 800);
    }
    showControls();
  };

  // Drag na barra de progresso
  vprogress.addEventListener('mousedown', function(e) {
    isDragging = true;
    wasPlayingBeforeDrag = !video.paused;
    if (wasPlayingBeforeDrag) video.pause();
    seekTo(e);
  });

  document.addEventListener('mousemove', function(e) {
    if (!isDragging) {
      // Tooltip de preview
      if (video.duration) {
        var rect = vprogress.getBoundingClientRect();
        if (e.clientX >= rect.left && e.clientX <= rect.right && e.clientY >= rect.top - 20 && e.clientY <= rect.bottom + 20) {
          var pos = (e.clientX - rect.left) / rect.width;
          progressTooltip.textContent = fmt(pos * video.duration);
          progressTooltip.style.left = (pos * 100) + '%';
        }
      }
      return;
    }
    seekTo(e);
  });

  document.addEventListener('mouseup', function() {
    if (isDragging) {
      isDragging = false;
      if (wasPlayingBeforeDrag) video.play();
    }
  });

  // Touch events para mobile
  vprogress.addEventListener('touchstart', function(e) {
    isDragging = true;
    wasPlayingBeforeDrag = !video.paused;
    if (wasPlayingBeforeDrag) video.pause();
    seekTo(e.touches[0]);
  }, { passive: true });

  vprogress.addEventListener('touchmove', function(e) {
    if (!isDragging) return;
    seekTo(e.touches[0]);
  }, { passive: true });

  vprogress.addEventListener('touchend', function() {
    if (isDragging) {
      isDragging = false;
      if (wasPlayingBeforeDrag) video.play();
    }
  });

  // ============================================
  // GESTOS E CLIQUES
  // ============================================
  window.handlePlayerClick = function(e) {
    var now = Date.now();
    var rect = pwrap.getBoundingClientRect();
    var x = e.clientX - rect.left;
    var y = e.clientY - rect.top;

    tapCount++;
    if (tapCount === 1) {
      tapTimer = setTimeout(function() {
        // Single tap
        if (controlsVisible) hideControls(); else showControls();
        tapCount = 0;
      }, 350);
    } else if (tapCount === 2 && now - lastTap < 350) {
      clearTimeout(tapTimer);
      tapCount = 0;
      // Double tap - seek
      seekRel(x < rect.width / 2 ? -10 : 10);
      createRipple(e.clientX, e.clientY);
      return;
    }
    lastTap = now;
  };

  // Touch events para mobile
  var touchStartX = 0;
  var touchStartY = 0;
  var touchStartTime = 0;
  var isTouching = false;

  pwrap.addEventListener('touchstart', function(e) {
    if (e.target.closest('.vbtn') || e.target.closest('.video-progress-container')) return;
    var touch = e.touches[0];
    touchStartX = touch.clientX;
    touchStartY = touch.clientY;
    touchStartTime = Date.now();
    isTouching = true;
  }, { passive: true });

  pwrap.addEventListener('touchmove', function(e) {
    if (!isTouching) return;
    var touch = e.touches[0];
    var deltaX = touch.clientX - touchStartX;
    var deltaY = touchStartY - touch.clientY;

    // Swipe horizontal para seek
    if (Math.abs(deltaX) > Math.abs(deltaY) && Math.abs(deltaX) > 30) {
      e.preventDefault();
      var seekAmount = deltaX > 0 ? 5 : -5;
      seekRel(seekAmount);
      touchStartX = touch.clientX;
    }
  }, { passive: false });

  pwrap.addEventListener('touchend', function(e) {
    if (!isTouching) return;
    isTouching = false;
    var touch = e.changedTouches[0];
    var deltaX = touch.clientX - touchStartX;
    var deltaY = touch.clientY - touchStartY;
    var deltaTime = Date.now() - touchStartTime;

    // Tap detection
    if (Math.abs(deltaX) < 10 && Math.abs(deltaY) < 10 && deltaTime < 300) {
      handlePlayerClick(touch);
    }
  }, { passive: true });

  // ============================================
  // VISIBILIDADE DOS CONTROLES
  // ============================================
  function showControls() {
    controlsVisible = true;
    pwrap.classList.add('show-controls');
    clearTimeout(controlsTimer);
    if (!video.paused) {
      controlsTimer = setTimeout(hideControls, 3500);
    }
  }

  function hideControls() {
    controlsVisible = false;
    pwrap.classList.remove('show-controls');
    speedMenu.classList.remove('show');
  }

  // Sempre mostrar controles quando pausado
  video.addEventListener('pause', function() {
    showControls();
    clearTimeout(controlsTimer);
  });

  video.addEventListener('play', function() {
    showControls();
  });

  // ============================================
  // VELOCIDADE DE REPRODUÇÃO
  // ============================================
  speedBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    speedMenu.classList.toggle('show');
  });

  document.querySelectorAll('.speed-option').forEach(function(opt) {
    opt.addEventListener('click', function(e) {
      e.stopPropagation();
      currentSpeed = parseFloat(this.dataset.speed);
      video.playbackRate = currentSpeed;
      speedBtn.textContent = currentSpeed + 'x';
      localStorage.setItem('ns_speed', currentSpeed);
      updateSpeedMenu();
      speedMenu.classList.remove('show');
    });
  });

  function updateSpeedMenu() {
    document.querySelectorAll('.speed-option').forEach(function(opt) {
      opt.classList.toggle('active', parseFloat(opt.dataset.speed) === currentSpeed);
    });
  }

  // ============================================
  // PICTURE IN PICTURE
  // ============================================
  if (document.pictureInPictureEnabled) {
    pipBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      if (document.pictureInPictureElement) {
        document.exitPictureInPicture();
      } else {
        video.requestPictureInPicture().catch(function(err) {
          console.warn('PiP error:', err);
        });
      }
    });
  } else {
    pipBtn.style.display = 'none';
  }

  // ============================================
  // SKIP INTRO
  // ============================================
  window.skipIntro = function() {
    if (video.duration) {
      video.currentTime = introEnd;
      skipIntroBtn.classList.remove('show');
      introSkipped = true;
    }
  };

  // ============================================
  // EVENTOS DO VÍDEO
  // ============================================
  video.addEventListener('timeupdate', function() {
    if (video.duration) {
      // Progresso
      vfill.style.width = (video.currentTime / video.duration * 100) + '%';
      vtime.textContent = fmt(video.currentTime) + ' / ' + fmt(video.duration);

      // Salvar progresso
      localStorage.setItem(getStorageKey(), String(video.currentTime));

      // Buffer indicator
      if (video.buffered.length > 0) {
        var bufferedEnd = video.buffered.end(video.buffered.length - 1);
        bufferIndicator.style.width = (bufferedEnd / video.duration * 100) + '%';
      }

      // Skip intro logic
      if (!introSkipped && video.currentTime >= introStart && video.currentTime < introEnd - 5) {
        skipIntroBtn.classList.add('show');
      } else {
        skipIntroBtn.classList.remove('show');
      }
    }
  });

  video.addEventListener('waiting', function() {
    pwrap.classList.add('buffering');
  });

  video.addEventListener('playing', function() {
    pwrap.classList.remove('buffering');
    document.getElementById('vloading').classList.add('hidden');
  });

  video.addEventListener('canplay', function() {
    pwrap.classList.remove('buffering');
  });

  video.addEventListener('loadeddata', function() {
    document.getElementById('vloading').classList.add('hidden');
    initPlayer();
  });

  video.addEventListener('loadedmetadata', function() {
    vtime.textContent = '0:00 / ' + fmt(video.duration || 0);
  });

  video.addEventListener('volumechange', function() {
    updateMuteButton();
  });

  window.onVideoEnd = function() {
    updatePlayButton(false);
    localStorage.removeItem(getStorageKey());

    <% if (nextEpisode) { %>
    // Countdown para próximo episódio
    var seconds = 5;
    nextCountdown.classList.add('show');
    countdownNum.textContent = seconds;

    countdownInterval = setInterval(function() {
      seconds--;
      countdownNum.textContent = seconds;
      if (seconds <= 0) {
        clearInterval(countdownInterval);
        location.href = '/watch/<%= anime.id %>/<%= nextEpisode.id %>';
      }
    }, 1000);

    // Cancelar countdown ao clicar
    nextCountdown.addEventListener('click', function(e) {
      e.stopPropagation();
      clearInterval(countdownInterval);
      nextCountdown.classList.remove('show');
    });
    <% } %>
  };

  // ============================================
  // TECLADO
  // ============================================
  document.addEventListener('keydown', function(e) {
    if (!video || e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

    switch(e.key.toLowerCase()) {
      case ' ':
      case 'k':
        e.preventDefault();
        togglePlay();
        break;
      case 'arrowright':
        e.preventDefault();
        seekRel(e.shiftKey ? 60 : 10);
        break;
      case 'arrowleft':
        e.preventDefault();
        seekRel(e.shiftKey ? -60 : -10);
        break;
      case 'arrowup':
        e.preventDefault();
        video.volume = Math.min(1, video.volume + 0.1);
        volumeSlider.value = video.volume;
        localStorage.setItem('ns_volume', video.volume);
        break;
      case 'arrowdown':
        e.preventDefault();
        video.volume = Math.max(0, video.volume - 0.1);
        volumeSlider.value = video.volume;
        localStorage.setItem('ns_volume', video.volume);
        break;
      case 'f':
        e.preventDefault();
        toggleFullscreen();
        break;
      case 'm':
        e.preventDefault();
        toggleMute();
        break;
      case 'j':
        e.preventDefault();
        seekRel(-10);
        break;
      case 'l':
        e.preventDefault();
        seekRel(10);
        break;
      case ',':
        e.preventDefault();
        if (video.paused) video.currentTime = Math.max(0, video.currentTime - (1/30));
        break;
      case '.':
        e.preventDefault();
        if (video.paused) video.currentTime = Math.min(video.duration, video.currentTime + (1/30));
        break;
      case '0': case '1': case '2': case '3': case '4':
      case '5': case '6': case '7': case '8': case '9':
        e.preventDefault();
        var percent = parseInt(e.key) * 10;
        video.currentTime = (percent / 100) * video.duration;
        showControls();
        break;
    }
  });

  // ============================================
  // CLIQUES NOS BOTÕES
  // ============================================
  playBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    togglePlay();
  });

  muteBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    toggleMute();
  });

  fullscreenBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    toggleFullscreen();
  });

  centerPlay.addEventListener('click', function(e) {
    e.stopPropagation();
    togglePlay();
  });

  // Fechar menus ao clicar fora
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.speed-btn') && !e.target.closest('.speed-menu')) {
      speedMenu.classList.remove('show');
    }
  });

  // ============================================
  // VISIBILIDADE DA PÁGINA
  // ============================================
  document.addEventListener('visibilitychange', function() {
    if (document.hidden && !video.paused && isMobile) {
      // Opcional: pausar ao sair do app no mobile
      // video.pause();
    }
  });

  // ============================================
  // PREVENIR MENU DE CONTEXTO NO MOBILE
  // ============================================
  pwrap.addEventListener('contextmenu', function(e) {
    e.preventDefault();
  });

  // ============================================
  // INICIALIZAÇÃO FINAL
  // ============================================
  if (video) {
    // Restaurar estado mudo
    var savedMuted = localStorage.getItem('ns_muted');
    if (savedMuted === 'true') {
      video.muted = true;
      updateMuteButton();
    }
  }

  // Console info
  console.log('🎬 Player NS - Mobile: ' + isMobile + ', iOS: ' + isIOS);

})();
</script>
<script src="/js/main.js"></script>
</body>
</html>