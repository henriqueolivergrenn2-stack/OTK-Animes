<!DOCTYPE html>
<html lang="pt-BR">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/nav') %>

<!-- Anime Hero -->
<section class="anime-hero">
  <div class="anime-hero-bg">
    <img src="<%= anime.cover || '' %>" alt="<%= anime.title || '' %>">
  </div>
  <div class="container" style="position:relative;z-index:1;width:100%">
    <div class="anime-hero-content">
      <div class="anime-hero-poster">
        <img src="<%= anime.cover || '' %>" alt="<%= anime.title || '' %>">
      </div>
      <div class="anime-hero-info">
        <h1><%= anime.title || 'Sem titulo' %></h1>
        <div class="anime-hero-meta">
          <span><%= anime.views || 0 %> views</span>
          <span><%= (episodes || []).length %> eps</span>
          <span>
            <% if (anime.status === 'ongoing') { %>Em andamento<% } else if (anime.status === 'completed') { %>Completo<% } else { %>Em breve<% } %>
          </span>
        </div>

        <div class="sinopse-wrapper">
          <p class="anime-hero-synopsis" id="sinopse-texto">
            <%= anime.synopsis || 'Sem sinopse.' %>
          </p>
          <% if ((anime.synopsis || '').length > 120) { %>
          <button class="btn-toggle-sinopse" id="btn-sinopse" onclick="handleSinopse()">Ler mais</button>
          <% } %>
        </div>

        <div style="margin-top:8px">
          <% (anime.genres || []).forEach(function(g) { %>
          <span class="anime-tag"><%= g %></span>
          <% }) %>
        </div>
        <% if (episodes && episodes.length > 0) { %>
        <div class="anime-hero-actions">
          <a href="/watch/<%= anime.id %>/<%= episodes[0].id %>" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Assistir EP 1
          </a>
          <% if (episodes.length > 1) { %>
          <a href="/watch/<%= anime.id %>/<%= episodes[episodes.length-1].id %>" class="btn btn-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            Ultimo EP
          </a>
          <% } %>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<!-- Popup Mobile (bottom sheet) -->
<div id="popup-overlay" onclick="fecharPopup()"></div>
<div id="popup-sheet">
  <div class="popup-handle"></div>
  <div class="popup-header">
    <span class="popup-titulo">Sinopse</span>
    <button class="popup-close" onclick="fecharPopup()">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
  <div class="popup-body">
    <p id="popup-sinopse-texto"></p>
  </div>
</div>

<div class="container">
  <section class="episodes-section">
    <div class="section-header">
      <h2 class="section-title">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
        Episodios (<%= (episodes || []).length %>)
      </h2>
    </div>
    <% if (!episodes || episodes.length === 0) { %>
    <div class="empty-state">
      <p>Nenhum episodio disponivel.</p>
      <% if (user && user.role === 'admin') { %>
      <a href="/admin/episodes/new" class="btn btn-primary" style="margin-top:12px">+ Adicionar Episodio</a>
      <% } %>
    </div>
    <% } else { %>
    <div class="episodes-grid">
      <% episodes.forEach(function(ep) { %>
      <div class="episode-card" onclick="location.href='/watch/<%= anime.id %>/<%= ep.id %>'">
        <div class="episode-card-thumb">
          <img src="<%= ep.thumbnail || anime.cover || '' %>" alt="<%= ep.title || '' %>">
        </div>
        <div class="episode-card-info">
          <div class="episode-card-number">EP <%= ep.number || '?' %></div>
          <div class="episode-card-title"><%= ep.title || ('Episodio ' + ep.number) %></div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </section>
</div>

<%- include('partials/footer') %>
<script src="/js/main.js"></script>

<style>
  /* ── Sinopse base ── */
  .sinopse-wrapper {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  #sinopse-texto {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
    line-height: 1.6;
  }

  /* Desktop expandido inline */
  #sinopse-texto.expandido {
    display: block;
    -webkit-line-clamp: unset;
    overflow: visible;
  }

  .btn-toggle-sinopse {
    background: none;
    border: none;
    color: var(--primary, #6c63ff);
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0;
    text-align: left;
    text-decoration: underline;
    width: fit-content;
  }
  .btn-toggle-sinopse:hover { opacity: 0.8; }

  /* ── Bottom Sheet Mobile ── */
  #popup-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 9998;
  }

  #popup-sheet {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: #1a1a2e;
    border-radius: 20px 20px 0 0;
    padding: 12px 20px 32px;
    max-height: 75vh;
    overflow-y: auto;
    box-shadow: 0 -4px 30px rgba(0,0,0,0.5);
    animation: slideUp 0.3s ease;
  }

  @keyframes slideUp {
    from { transform: translateY(100%); }
    to   { transform: translateY(0); }
  }

  #popup-overlay.ativo,
  #popup-sheet.ativo {
    display: block;
  }

  .popup-handle {
    width: 40px;
    height: 4px;
    background: rgba(255,255,255,0.25);
    border-radius: 2px;
    margin: 0 auto 16px;
  }

  .popup-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .popup-titulo {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
  }

  .popup-close {
    background: rgba(255,255,255,0.1);
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #fff;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .popup-close:hover { background: rgba(255,255,255,0.25); }

  .popup-body p {
    color: #ccc;
    font-size: 0.95rem;
    line-height: 1.8;
    margin: 0;
  }
</style>

<script>
  var sinopseCompleta = document.getElementById('sinopse-texto') 
    ? document.getElementById('sinopse-texto').textContent.trim() 
    : '';

  function isMobile() {
    return window.innerWidth < 768;
  }

  function handleSinopse() {
    if (isMobile()) {
      abrirPopup();
    } else {
      toggleDesktop();
    }
  }

  /* Mobile: abre bottom sheet */
  function abrirPopup() {
    document.getElementById('popup-sinopse-texto').textContent = sinopseCompleta;
    document.getElementById('popup-overlay').classList.add('ativo');
    document.getElementById('popup-sheet').classList.add('ativo');
    document.body.style.overflow = 'hidden';
  }

  function fecharPopup() {
    document.getElementById('popup-overlay').classList.remove('ativo');
    document.getElementById('popup-sheet').classList.remove('ativo');
    document.body.style.overflow = '';
  }

  /* Desktop: expande inline */
  function toggleDesktop() {
    var texto = document.getElementById('sinopse-texto');
    var btn = document.getElementById('btn-sinopse');
    if (texto.classList.contains('expandido')) {
      texto.classList.remove('expandido');
      btn.textContent = 'Ler mais';
    } else {
      texto.classList.add('expandido');
      btn.textContent = 'Ler menos';
    }
  }

  /* Fechar com Esc */
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') fecharPopup();
  });
</script>
</body>
</html>