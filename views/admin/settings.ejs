<!DOCTYPE html>
<html lang="pt-BR">
<head><%- include('../partials/head') %></head>
<body>
<div class="admin-layout">
<%- include('sidebar', { active: 'settings' }) %>
<main class="admin-main" style="margin-left:0;padding:16px;padding-top:72px">
  <div class="admin-nav-mobile">
    <a href="/admin">Dashboard</a>
    <a href="/admin/animes">Animes</a>
    <a href="/admin/episodes">Episodios</a>
    <a href="/admin/users">Usuarios</a>
    <a href="/admin/settings" class="active">Config</a>
  </div>
  <div class="admin-header-mobile"><h1>Configuracoes</h1></div>

  <% if (success) { %><div class="auth-success" style="margin-bottom:16px"><%= success %></div><% } %>
  <% if (error) { %><div class="auth-error" style="margin-bottom:16px"><%= error %></div><% } %>

  <div class="admin-card" style="padding:20px">
    <h3 style="margin-bottom:16px;font-size:18px">Alterar Email e Senha</h3>
    <form class="admin-form" method="POST" action="/admin/settings">
      <div>
        <label>Email</label>
        <input type="email" name="email" value="<%= user.email || '' %>" required>
      </div>
      <div>
        <label>Senha Atual *</label>
        <input type="password" name="currentPassword" required placeholder="Senha atual para confirmar">
      </div>
      <div>
        <label>Nova Senha (deixe em branco para nao alterar)</label>
        <input type="password" name="newPassword" placeholder="Minimo 6 caracteres">
      </div>
      <button type="submit" class="btn btn-primary">Salvar Alteracoes</button>
    </form>
  </div>

  <div style="margin-top:20px;text-align:center">
    <a href="/logout" class="btn btn-danger">Sair da Conta</a>
  </div>
</main>
</div>
</body>
</html>
