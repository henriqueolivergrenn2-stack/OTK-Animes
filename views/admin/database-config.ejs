<!DOCTYPE html>
<html lang="pt-BR">
<head><%- include('../partials/head') %></head>
<body>
<div class="admin-layout">
<%- include('sidebar', { active: 'database' }) %>
<main class="admin-main" style="margin-left:0;padding:16px;padding-top:72px">

  <div class="admin-nav-mobile">
    <a href="/admin">Dashboard</a>
    <a href="/admin/animes">Animes</a>
    <a href="/admin/episodes">Episodios</a>
    <a href="/admin/users">Usuarios</a>
    <a href="/admin/database" class="active">Database</a>
    <a href="/admin/settings">Config</a>
  </div>

  <div class="admin-header-mobile">
    <h1><%= providerCfg.label %></h1>
    <a href="/admin/database" class="btn btn-secondary btn-sm">Voltar</a>
  </div>

  <p style="color:var(--text-secondary);font-size:14px;margin-bottom:20px"><%= providerCfg.description %></p>

  <% if (success) { %>
  <div class="auth-success" style="margin-bottom:16px"><%= success %></div>
  <% } %>
  <% if (error) { %>
  <div class="auth-error" style="margin-bottom:16px"><%= error %></div>
  <% } %>

  <form class="admin-form" method="POST" action="/admin/database/config/<%= provider %>">
    <% fields.forEach(function(f) { %>
    <div>
      <label><%= f.label %></label>
      <% if (f.type === 'textarea') { %>
      <textarea name="<%= f.name %>" placeholder="<%= f.placeholder %>" rows="6"><%= providerCfg[f.name] || '' %></textarea>
      <% } else { %>
      <input type="<%= f.type %>" name="<%= f.name %>" value="<%= providerCfg[f.name] || '' %>" placeholder="<%= f.placeholder %>">
      <% } %>
      <% if (f.hint) { %>
      <p class="hint"><%= f.hint %></p>
      <% } %>
    </div>
    <% }) %>

    <div style="display:flex;gap:10px;flex-wrap:wrap">
      <button type="submit" class="btn btn-primary">Salvar Configuracao</button>
      <button type="button" class="btn btn-secondary" onclick="testConnection('<%= provider %>')">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Testar Conexao
      </button>
      <% if (provider !== 'json') { %>
      <button type="button" class="btn btn-primary" onclick="activateProvider('<%= provider %>')">
        Salvar e Ativar
      </button>
      <% } %>
    </div>
  </form>

  <!-- Guia rapido -->
  <div class="admin-card" style="margin-top:24px;padding:20px">
    <h3 style="font-size:16px;margin-bottom:12px;display:flex;align-items:center;gap:8px">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="var(--primary)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      Como configurar <%= providerCfg.label %>
    </h3>
    <div class="db-guide">
      <% if (provider === 'json') { %>
      <p>O JSON Local ja esta configurado! Nao precisa fazer nada. Os dados sao salvos automaticamente na pasta <code>data/</code>.</p>
      <% } %>
      <% if (provider === 'mongodb') { %>
      <ol>
        <li>Acesse <a href="https://www.mongodb.com/atlas" target="_blank">mongodb.com/atlas</a> e crie uma conta (gratuita)</li>
        <li>Crie um novo cluster <strong>M0 (Free)</strong></li>
        <li>Va em <strong>Database Access</strong> e crie um usuario</li>
        <li>Va em <strong>Network Access</strong> e adicione <code>0.0.0.0/0</code> (Allow from anywhere)</li>
        <li>Va em <strong>Database > Connect > Drivers > Node.js</strong></li>
        <li>Copie a <strong>Connection String</strong> e cole acima</li>
        <li>Substitua <code>&lt;password&gt;</code> pela senha do usuario</li>
      </ol>
      <p style="color:var(--success);font-weight:600">FREE TIER: 512MB storage, 1M reads/mes</p>
      <% } %>
      <% if (provider === 'firebase') { %>
      <ol>
        <li>Acesse <a href="https://console.firebase.google.com" target="_blank">console.firebase.google.com</a></li>
        <li>Crie um projeto novo</li>
        <li>Va em <strong>Project Settings (engrenagem) > Service Accounts</strong></li>
        <li>Clique em <strong>Generate new private key</strong></li>
        <li>Abra o arquivo JSON baixado e cole todo o conteudo no campo acima</li>
        <li>Volte em <strong>Project Settings > General</strong> e copie a Database URL</li>
      </ol>
      <p style="color:var(--success);font-weight:600">SPARK PLAN: 1GB storage, 50K reads/dia - GRATUITO!</p>
      <% } %>
      <% if (provider === 'supabase') { %>
      <ol>
        <li>Acesse <a href="https://supabase.com" target="_blank">supabase.com</a> e crie conta</li>
        <li>Crie um novo projeto</li>
        <li>Va em <strong>Table Editor</strong> e crie as tabelas: users, animes, episodes, history, settings (coluna id TEXT PRIMARY KEY, data JSONB)</li>
        <li>Va em <strong>Project Settings > API</strong></li>
        <li>Copie <strong>Project URL</strong> e <strong>anon public</strong> key</li>
      </ol>
      <p style="color:var(--success);font-weight:600">FREE TIER: 500MB storage, 2GB transferencia</p>
      <% } %>
      <% if (provider === 'planetscale') { %>
      <ol>
        <li>Acesse <a href="https://planetscale.com" target="_blank">planetscale.com</a> e crie conta</li>
        <li>Crie um novo database</li>
        <li>Va em <strong>Connect</strong> e selecione <strong>@planetscale/database</strong></li>
        <li>Copie Host, Username e Password</li>
      </ol>
      <p style="color:var(--success);font-weight:600">FREE TIER: 5GB storage, 1 billion rows</p>
      <% } %>
      <% if (provider === 'neon') { %>
      <ol>
        <li>Acesse <a href="https://neon.tech" target="_blank">neon.tech</a> e crie conta</li>
        <li>Crie um novo projeto</li>
        <li>Va em <strong>Connection Details</strong></li>
        <li>Selecione <strong>Node.js</strong> como linguagem</li>
        <li>Copie a <strong>Connection String</strong> completa</li>
      </ol>
      <p style="color:var(--success);font-weight:600">FREE TIER: 512MB storage</p>
      <% } %>
      <% if (provider === 'mysql') { %>
      <ol>
        <li>Voce precisa de um servidor MySQL rodando</li>
        <li>Opcoes: <strong>Local (XAMPP/WAMP)</strong>, <strong>AWS RDS Free Tier</strong>, <strong>Google Cloud SQL</strong>, <strong>DigitalOcean</strong></li>
        <li>Preencha host, porta, usuario, senha e nome do database</li>
      </ol>
      <% } %>
      <% if (provider === 'postgres') { %>
      <ol>
        <li>Voce precisa de um servidor PostgreSQL rodando</li>
        <li>Opcoes: <strong>Local</strong>, <strong>AWS RDS Free Tier</strong>, <strong>ElephantSQL (gratuito)</strong>, <strong>Render.com</strong></li>
        <li>Preencha host, porta, usuario, senha e nome do database</li>
      </ol>
      <% } %>
      <% if (provider === 'sqlite') { %>
      <ol>
        <li>Banco SQLite salva tudo em um arquivo .db</li>
        <li>Requer: <code>npm install better-sqlite3</code></li>
        <li>Deixe o caminho padrao ou escolha onde salvar</li>
        <li>Ideal para uso local/offline</li>
      </ol>
      <% } %>
      <% if (provider === 'redis') { %>
      <ol>
        <li>Acesse <a href="https://redis.io/cloud" target="_blank">redis.io/cloud</a> e crie conta</li>
        <li>Crie um novo database (Free 30MB)</li>
        <li>Va em <strong>Configuration</strong></li>
        <li>Copie Endpoint (host), Port e Password</li>
      </ol>
      <p style="color:var(--success);font-weight:600">FREE TIER: 30MB storage</p>
      <% } %>
      <% if (provider === 'dynamodb') { %>
      <ol>
        <li>Acesse <a href="https://aws.amazon.com" target="_blank">aws.amazon.com</a> e crie conta (12 meses free tier)</li>
        <li>Va em <strong>IAM > Users > Create User</strong></li>
        <li>Anexe a policy <strong>AmazonDynamoDBFullAccess</strong></li>
        <li>Va em <strong>Security Credentials > Create Access Key</strong></li>
        <li>Copie Access Key ID e Secret Access Key</li>
        <li>Va em <strong>DynamoDB</strong> e crie as tabelas: users, animes, episodes, history, settings (Partition key: id)</li>
      </ol>
      <p style="color:var(--success);font-weight:600">FREE TIER: 25GB storage, 25 unidades capacidade</p>
      <% } %>
      <% if (provider === 'cockroachdb') { %>
      <ol>
        <li>Acesse <a href="https://cockroachlabs.cloud" target="_blank">cockroachlabs.cloud</a> e crie conta</li>
        <li>Crie um novo cluster (Serverless)</li>
        <li>Va em <strong>Connect > Connection String</strong></li>
        <li>Selecione <strong>Node.js/pg</strong></li>
        <li>Copie a connection string completa</li>
      </ol>
      <p style="color:var(--success);font-weight:600">FREE TIER: 5GB storage, 250M Request Units</p>
      <% } %>
    </div>
  </div>

</main>
</div>

<style>
.db-guide { font-size: 13px; color: var(--text-secondary); line-height: 1.7; }
.db-guide ol { padding-left: 20px; margin-bottom: 12px; }
.db-guide li { margin-bottom: 6px; }
.db-guide a { color: var(--primary); }
.db-guide code { background: var(--bg-input); padding: 2px 8px; border-radius: 4px; font-size: 12px; color: var(--text); }
</style>

<script>
function testConnection(provider) {
  const btn = event.target.closest('button');
  btn.style.opacity = '0.6';
  btn.innerHTML = 'Testando...';
  fetch('/admin/database/test/' + provider, { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      btn.style.opacity = '1';
      btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> Testar Conexao';
      alert(data.success ? 'OK: ' + data.message : 'FALHOU: ' + data.message);
    })
    .catch(err => {
      btn.style.opacity = '1';
      btn.innerHTML = 'Testar Conexao';
      alert('Erro no teste: ' + err.message);
    });
}
function activateProvider(provider) {
  if (!confirm('Ativar ' + provider + '?')) return;
  fetch('/admin/database/activate/' + provider, { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        alert(data.message);
        location.href = '/admin/database';
      } else {
        alert('Erro: ' + data.message);
      }
    })
    .catch(err => alert('Erro: ' + err.message));
}
</script>

</body>
</html>
