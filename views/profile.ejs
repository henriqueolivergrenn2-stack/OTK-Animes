<!DOCTYPE html>
<html lang="pt-BR">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/nav') %>

<div class="container" style="padding-top:20px">
  <div class="profile-header">
    <img src="<%= user.avatar || '' %>" alt="" class="profile-avatar">
    <div class="profile-info">
      <h1><%= user.name || 'Usuario' %></h1>
      <p><%= user.email || '' %> &bull; <%= user.role === 'admin' ? 'Administrador' : 'Usuario' %></p>
    </div>
  </div>

  <section class="content-section">
    <div class="section-header">
      <h2 class="section-title">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Historico
      </h2>
    </div>
    <% if (!history || history.length === 0) { %>
    <div class="empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" style="margin:0 auto 12px;opacity:0.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <h3>Nada ainda</h3>
      <p>Voce ainda nao assistiu nenhum episodio.</p>
      <a href="/catalogo" class="btn btn-primary" style="margin-top:12px">Explorar</a>
    </div>
    <% } else { %>
    <div class="history-grid">
      <% history.forEach(function(h) { %>
      <a href="/watch/<%= h.animeId %>/<%= h.episodeId %>" class="history-card">
        <img src="<%= h.animeCover || '' %>" alt="">
        <div class="history-card-info">
          <div class="history-card-title"><%= h.animeTitle || '' %></div>
          <div class="history-card-ep">EP <%= h.episodeNumber || '?' %></div>
          <div class="history-card-time"><%= h.watchedAt ? new Date(h.watchedAt).toLocaleDateString('pt-BR') : '' %></div>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>
  </section>

  <% if (user.role === 'admin') { %>
  <div style="text-align:center;margin-top:24px">
    <a href="/admin" class="btn btn-primary">Painel Admin</a>
  </div>
  <% } %>

  <div style="text-align:center;margin-top:16px;margin-bottom:24px">
    <a href="/logout" class="btn btn-danger" style="font-size:13px">Sair da Conta</a>
  </div>
</div>

<%- include('partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
