<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/nav') %>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-bg">
      <img src="https://images.unsplash.com/photo-1578632767115-351597cf2477?w=1920&q=80" alt="OTK Animes" loading="eager">
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-badge">🔥 Novo por dia</div>
      <h1>OTK <span>ANIMES</span></h1>
      <p>Assista aos melhores animes. Player otimizado para Android.</p>
      <div class="hero-buttons">
        <a href="/catalogo" class="btn-hero btn-hero-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Explorar
        </a>
        <% if (!user) { %>
        <a href="/login" class="btn-hero btn-hero-secondary">Entrar</a>
        <a href="/register" class="btn-hero btn-hero-ghost">Criar Conta</a>
        <% } %>
      </div>
    </div>
  </section>

  <div class="container">

    <!-- ===== DESTAQUES ===== -->
    <% if (featured && featured.length > 0) { %>
    <section class="content-section anim-section">
      <div class="section-header">
        <h2 class="section-title">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
          </svg>
          Destaques
        </h2>
      </div>
      <div class="featured-grid">
        <% featured.forEach(function(a) { %>
        <div class="featured-card" onclick="location.href='/anime/<%= a.id %>'">
          <img src="<%= a.cover || '' %>" alt="<%= a.title || '' %>" loading="lazy">
          <div class="featured-card-overlay">
            <span class="featured-card-badge">TOP</span>
            <div class="featured-card-title"><%= a.title || '' %></div>
            <div class="featured-card-meta">
              <%=(a.genres||[]).slice(0,2).join(', ')%> &bull; <%= a.views || 0 %> views
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </section>
    <% } %>

    <!-- ===== EPISODIOS RECENTES ===== -->
    <% if (recentEpisodes && recentEpisodes.length > 0) { %>
    <section class="content-section anim-section">
      <div class="section-header">
        <h2 class="section-title">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Episodios Recentes
        </h2>
      </div>
      <div class="carousel">
        <% recentEpisodes.forEach(function(ep) { %>
        <div class="carousel-card" onclick="location.href='/watch/<%= ep.animeId %>/<%= ep.id %>'">
          <div class="carousel-card-thumb">
            <img src="<%= ep.thumbnail || ep.animeCover || '' %>" alt="<%= ep.title || '' %>" loading="lazy">
            <span class="carousel-card-badge">EP <%= ep.number || '?' %></span>
          </div>
          <div class="carousel-card-info">
            <div class="carousel-card-title"><%= ep.title || ('EP ' + ep.number) %></div>
            <div class="carousel-card-meta"><%= ep.animeTitle || '' %></div>
          </div>
        </div>
        <% }) %>
      </div>
    </section>
    <% } %>

    <!-- ===== POPULARES ===== -->
    <% if (popularAnimes && popularAnimes.length > 0) { %>
    <section class="content-section anim-section">
      <div class="section-header">
        <h2 class="section-title">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/>
          </svg>
          Populares
        </h2>
        <a href="/catalogo?sort=popular" class="section-more">Ver todos &rarr;</a>
      </div>
      <div class="anime-grid">
        <% popularAnimes.forEach(function(a, i) { %>
        <div class="anime-card" onclick="location.href='/anime/<%= a.id %>'">
          <% if (i < 3) { %>
          <div class="anime-card-rank top<%= i+1 %>"><%= i+1 %></div>
          <% } %>
          <div class="anime-card-cover">
            <img src="<%= a.cover || '' %>" alt="<%= a.title || '' %>" loading="lazy">
          </div>
          <div class="anime-card-info">
            <div class="anime-card-title"><%= a.title || '' %></div>
            <div class="anime-card-genres">
              <% (a.genres || []).slice(0,2).forEach(function(g) { %>
              <span class="anime-card-genre"><%= g %></span>
              <% }) %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </section>
    <% } %>

    <!-- ===== ADICIONADOS RECENTEMENTE ===== -->
    <% if (recentAnimes && recentAnimes.length > 0) { %>
    <section class="content-section anim-section">
      <div class="section-header">
        <h2 class="section-title">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
          </svg>
          Novos
        </h2>
        <a href="/catalogo?sort=recent" class="section-more">Ver todos &rarr;</a>
      </div>
      <div class="anime-grid">
        <% recentAnimes.forEach(function(a) { %>
        <div class="anime-card" onclick="location.href='/anime/<%= a.id %>'">
          <div class="anime-card-cover">
            <img src="<%= a.cover || '' %>" alt="<%= a.title || '' %>" loading="lazy">
          </div>
          <div class="anime-card-info">
            <div class="anime-card-title"><%= a.title || '' %></div>
            <div class="anime-card-genres">
              <% (a.genres || []).slice(0,2).forEach(function(g) { %>
              <span class="anime-card-genre"><%= g %></span>
              <% }) %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </section>
    <% } %>

    <!-- ===== ESTADO VAZIO ===== -->
    <% if ((!featured || !featured.length) && (!recentEpisodes || !recentEpisodes.length) && (!popularAnimes || !popularAnimes.length)) { %>
    <section class="content-section">
      <div class="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" style="margin:0 auto 16px;opacity:0.4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/>
        </svg>
        <h3>Bem-vindo ao OTK ANIMES</h3>
        <p>Seu catalogo esta vazio. Comece adicionando seu primeiro anime pelo painel admin!</p>
        <% if (user && user.role === 'admin') { %>
        <a href="/admin/animes/new" class="btn-hero btn-hero-primary" style="margin-top:12px">+ Adicionar Anime</a>
        <% } else { %>
        <a href="/login" class="btn-hero btn-hero-primary" style="margin-top:12px">Entrar como Admin</a>
        <% } %>
      </div>
    </section>
    <% } %>

  </div>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>

  <style>
    /* ── Hero melhorado ── */
    .hero {
      position: relative;
      overflow: hidden;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to right,
        rgba(0,0,0,0.85) 0%,
        rgba(0,0,0,0.4) 60%,
        rgba(0,0,0,0.1) 100%
      );
      z-index: 0;
    }

    .hero-content {
      position: relative;
      z-index: 1;
      animation: heroEntrada 0.5s ease both;
    }

    @keyframes heroEntrada {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .hero-badge {
      display: inline-block;
      background: rgba(255, 107, 53, 0.2);
      border: 1px solid rgba(255, 107, 53, 0.4);
      color: #ff8c42;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      padding: 4px 12px;
      border-radius: 20px;
      margin-bottom: 14px;
      animation: heroEntrada 0.5s ease 0.05s both;
    }

    .hero-content h1 {
      animation: heroEntrada 0.5s ease 0.1s both;
    }

    .hero-content p {
      animation: heroEntrada 0.5s ease 0.15s both;
    }

    .hero-buttons {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      animation: heroEntrada 0.5s ease 0.2s both;
    }

    /* Botão ghost novo */
    .btn-hero-ghost {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.2);
      color: #fff;
      padding: 10px 20px;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.18s ease, border-color 0.18s ease;
    }
    .btn-hero-ghost:hover {
      background: rgba(255,255,255,0.15);
      border-color: rgba(255,255,255,0.35);
    }

    /* Botões hero existentes — suavizar */
    .btn-hero {
      transition: opacity 0.15s ease, transform 0.15s ease;
      will-change: transform;
    }
    .btn-hero:hover  { opacity: 0.88; transform: translateY(-1px); }
    .btn-hero:active { opacity: 1;    transform: translateY(0); }

    /* ── Sections com entrada por scroll ── */
    .anim-section {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .anim-section.visivel {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Cards — hover GPU-only ── */
    .anime-card,
    .featured-card,
    .carousel-card {
      transition: transform 0.18s ease, opacity 0.18s ease;
      will-change: transform;
    }
    .anime-card:hover,
    .featured-card:hover,
    .carousel-card:hover {
      transform: translateY(-3px);
      opacity: 0.92;
    }
    .anime-card:active,
    .featured-card:active,
    .carousel-card:active {
      transform: translateY(0);
      opacity: 1;
    }

    /* ── Section-more link ── */
    .section-more {
      transition: opacity 0.15s ease;
    }
    .section-more:hover { opacity: 0.7; }
  </style>

  <script>
    /* Intersection Observer — anima sections quando entram na tela */
    /* Mais leve que scroll listener, não trava FPS */
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visivel');
            observer.unobserve(entry.target); /* para de observar depois de animar */
          }
        });
      }, { threshold: 0.08 });

      document.querySelectorAll('.anim-section').forEach(function(el) {
        observer.observe(el);
      });
    } else {
      /* Fallback pra browsers antigos: mostra tudo direto */
      document.querySelectorAll('.anim-section').forEach(function(el) {
        el.classList.add('visivel');
      });
    }
  </script>

</body>
</html>