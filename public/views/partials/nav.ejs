<!-- ===== BOTTOM NAVBAR (Mobile-First) ===== -->
<nav class="bottom-nav" id="bottomNav">
  <a href="/" class="nav-item <%= (typeof activeNav !== 'undefined' && activeNav === 'home') || (!typeof activeNav) ? 'active' : '' %>">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
    <span>Inicio</span>
  </a>
  <a href="/catalogo" class="nav-item <%= typeof activeNav !== 'undefined' && activeNav === 'catalog' ? 'active' : '' %>">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
    <span>Catalogo</span>
  </a>
  <% if (user) { %>
  <a href="/profile" class="nav-item <%= typeof activeNav !== 'undefined' && activeNav === 'profile' ? 'active' : '' %>">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
    <span>Perfil</span>
  </a>
  <% } else { %>
  <a href="/login" class="nav-item">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
    <span>Entrar</span>
  </a>
  <% } %>
</nav>

<!-- ===== TOP HEADER ===== -->
<header class="top-header" id="topHeader">
  <div class="top-header-inner">
    <a href="/" class="top-logo">
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="32" height="32" rx="8" fill="url(#logoGrad)"/>
        <path d="M12 10L22 16L12 22V10Z" fill="white"/>
        <defs><linearGradient id="logoGrad" x1="0" y1="0" x2="32" y2="32"><stop offset="0%" stop-color="#ff6b35"/><stop offset="100%" stop-color="#ff8c42"/></linearGradient></defs>
      </svg>
      <span>OTK</span>
    </a>
    
    <!-- Search Toggle -->
    <button class="search-toggle" id="searchToggle" onclick="toggleSearch()">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
    </button>
  </div>
  
  <!-- Expandable Search Bar -->
  <div class="search-bar" id="searchBar">
    <form action="/catalogo" method="GET" class="search-form">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <input type="text" name="q" placeholder="Buscar anime..." autocomplete="off">
      <button type="button" class="search-close" onclick="toggleSearch()">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </form>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="header-spacer"></div>
