<!DOCTYPE html>
<html lang="pt-BR">
<head><%- include('../partials/head') %></head>
<body>
<div class="admin-layout">
<%- include('sidebar', { active: 'animes' }) %>
<main class="admin-main" style="margin-left:0;padding:16px;padding-top:72px">
  <div class="admin-nav-mobile">
    <a href="/admin">Dashboard</a>
    <a href="/admin/animes" class="active">Animes</a>
    <a href="/admin/episodes">Episodios</a>
    <a href="/admin/users">Usuarios</a>
    <a href="/admin/settings">Config</a>
  </div>
  <div class="admin-header-mobile">
    <h1>Animes</h1>
    <a href="/admin/animes/new" class="btn btn-primary btn-sm">+ Novo</a>
  </div>
  <form method="GET" action="/admin/animes" class="admin-search">
    <input type="text" name="q" value="<%= q || '' %>" placeholder="Buscar anime...">
    <button type="submit" class="btn btn-primary btn-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
    </button>
  </form>
  <div class="admin-card">
    <div class="admin-list">
      <% if (!animes || !animes.length) { %>
      <div class="admin-empty">Nenhum anime.<br><a href="/admin/animes/new">Adicionar primeiro</a></div>
      <% } else { %>
      <% animes.forEach(function(a) { %>
      <div class="admin-list-item" onclick="location.href='/admin/animes/edit/<%= a.id %>'" style="cursor:pointer">
        <img src="<%= a.cover || '' %>" alt="">
        <div class="admin-list-item-info">
          <div class="admin-list-item-title"><%= a.title || '' %></div>
          <div class="admin-list-item-meta"><%=(a.genres||[]).join(', ')%> &bull; <%= a.views||0 %> views</div>
        </div>
        <div class="admin-list-item-actions" onclick="event.stopPropagation()">
          <a href="/admin/animes/edit/<%= a.id %>" class="btn btn-sm btn-secondary">Editar</a>
          <a href="/admin/animes/delete/<%= a.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Excluir este anime?')">Excluir</a>
        </div>
      </div>
      <% }) %>
      <% } %>
    </div>
  </div>
</main>
</div>
</body>
</html>
