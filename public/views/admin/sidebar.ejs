<style>
.admin-sidebar-desktop { display: none; }
.admin-nav-desktop { display: flex; flex-direction: column; gap: 4px; }
.admin-nav-desktop a {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  border-radius: 12px;
  color: var(--text-secondary);
  text-decoration: none;
  font-size: 14px;
  font-weight: 600;
  transition: var(--transition);
}
.admin-nav-desktop a:hover { background: rgba(255,255,255,0.05); color: var(--text); }
.admin-nav-desktop a.active { background: rgba(255,107,53,0.15); color: var(--primary); }
@media (min-width: 1024px) {
  .admin-sidebar-desktop { display: block !important; position: fixed; top: 0; left: 0; bottom: 0; width: 240px; background: var(--bg-card); border-right: 1px solid var(--border); padding: 24px; z-index: 100; }
  .admin-main { margin-left: 240px !important; padding: 32px !important; padding-top: 32px !important; }
  .admin-nav-mobile { display: none !important; }
  .admin-header-mobile { padding-top: 0 !important; }
}
</style>
