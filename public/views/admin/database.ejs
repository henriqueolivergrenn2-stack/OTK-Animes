<!DOCTYPE html>
<html lang="pt-BR">
<head><%- include('../partials/head') %></head>
<body>
<div class="admin-layout">
<%- include('sidebar', { active: 'database' }) %>
<main class="admin-main" style="margin-left:0;padding:16px;padding-top:72px">

  <!-- Mobile Nav -->
  <div class="admin-nav-mobile">
    <a href="/admin">Dashboard</a>
    <a href="/admin/animes">Animes</a>
    <a href="/admin/episodes">Episodios</a>
    <a href="/admin/users">Usuarios</a>
    <a href="/admin/database" class="active">Database</a>
    <a href="/admin/settings">Config</a>
  </div>

  <div class="admin-header-mobile">
    <h1>Banco de Dados</h1>
  </div>

  <!-- Status atual -->
  <div class="admin-card" style="padding:20px;margin-bottom:20px;background:linear-gradient(135deg,rgba(255,107,53,0.1),rgba(255,107,53,0.05));border-color:rgba(255,107,53,0.3)">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="var(--primary)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/></svg>
      <div>
        <div style="font-size:12px;color:var(--text-muted);font-weight:700;text-transform:uppercase;letter-spacing:0.5px">Provider Ativo</div>
        <div style="font-size:20px;font-weight:800;color:var(--primary)"><%= providers[activeProvider] ? providers[activeProvider].label : activeProvider %></div>
      </div>
    </div>
    <p style="font-size:13px;color:var(--text-secondary);margin:0"><%= providers[activeProvider] ? providers[activeProvider].description : '' %></p>
  </div>

  <!-- Providers Grid -->
  <div class="db-providers-grid">
    <% Object.keys(providers).forEach(function(key) { const p = providers[key]; %>
    <div class="db-provider-card <%= key === activeProvider ? 'active' : '' %> <%= p.enabled ? 'configured' : '' %>">
      <div class="db-provider-header">
        <div class="db-provider-icon">
          <% if (key === 'json') { %>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <% } else if (key === 'mongodb') { %>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
          <% } else if (key === 'firebase') { %>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/></svg>
          <% } else if (key === 'supabase') { %>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          <% } else if (key === 'planetscale') { %>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
          <% } else if (key === 'neon') { %>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          <% } else if (key === 'sqlite') { %>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/></svg>
          <% } else { %>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/></svg>
          <% } %>
        </div>
        <div class="db-provider-info">
          <div class="db-provider-name"><%= p.label %></div>
          <div class="db-provider-desc"><%= p.description %></div>
        </div>
        <% if (key === activeProvider) { %>
        <span class="db-badge-active">ATIVO</span>
        <% } else if (p.enabled) { %>
        <span class="db-badge-configured">OK</span>
        <% } else { %>
        <span class="db-badge-default">Padrao</span>
        <% } %>
      </div>

      <!-- Free tier info -->
      <div class="db-provider-free">
        <% if (key === 'json') { %>Sem dependencias - ja funciona!<% } %>
        <% if (key === 'mongodb') { %>FREE: 512MB | mongodb.com/atlas<% } %>
        <% if (key === 'firebase') { %>FREE: 1GB | firebase.google.com<% } %>
        <% if (key === 'supabase') { %>FREE: 500MB | supabase.com<% } %>
        <% if (key === 'planetscale') { %>FREE: 5GB | planetscale.com<% } %>
        <% if (key === 'neon') { %>FREE: 512MB | neon.tech<% } %>
        <% if (key === 'mysql') { %>Proprio - necessita servidor<% } %>
        <% if (key === 'postgres') { %>Proprio - necessita servidor<% } %>
        <% if (key === 'sqlite') { %>Local - arquivo .db<% } %>
        <% if (key === 'redis') { %>FREE: 30MB | redis.io/cloud<% } %>
        <% if (key === 'dynamodb') { %>FREE: 25GB | aws.amazon.com<% } %>
        <% if (key === 'cockroachdb') { %>FREE: 5GB | cockroachlabs.cloud<% } %>
      </div>

      <div class="db-provider-actions">
        <a href="/admin/database/config/<%= key %>" class="btn btn-sm btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Configurar
        </a>
        <% if (key !== activeProvider) { %>
        <button onclick="activateProvider('<%= key %>')" class="btn btn-sm btn-primary" <%= !p.enabled ? 'disabled style=opacity:0.5' : '' %>>
          Ativar
        </button>
        <% } %>
        <% if (key !== 'json' && key !== activeProvider && p.enabled) { %>
        <button onclick="migrateTo('<%= key %>')" class="btn btn-sm btn-secondary">
          Migrar
        </button>
        <% } %>
      </div>
    </div>
    <% }) %>
  </div>

</main>
</div>

<style>
.db-providers-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
}
@media (min-width: 768px) {
  .db-providers-grid { grid-template-columns: repeat(2, 1fr); }
}
.db-provider-card {
  background: var(--bg-card);
  border: 2px solid var(--border);
  border-radius: 16px;
  padding: 20px;
  transition: all 0.25s ease;
}
.db-provider-card.active {
  border-color: var(--primary);
  box-shadow: 0 0 20px rgba(255,107,53,0.15);
}
.db-provider-header {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 12px;
}
.db-provider-icon {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  background: rgba(255,107,53,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
  flex-shrink: 0;
}
.db-provider-info { flex: 1; min-width: 0; }
.db-provider-name { font-size: 16px; font-weight: 700; margin-bottom: 3px; }
.db-provider-desc { font-size: 12px; color: var(--text-muted); line-height: 1.4; }
.db-badge-active {
  background: var(--primary);
  color: white;
  font-size: 10px;
  font-weight: 800;
  padding: 4px 10px;
  border-radius: 20px;
  white-space: nowrap;
}
.db-badge-configured {
  background: rgba(46,213,115,0.15);
  color: var(--success);
  font-size: 10px;
  font-weight: 800;
  padding: 4px 10px;
  border-radius: 20px;
  white-space: nowrap;
}
.db-badge-default {
  background: var(--bg-input);
  color: var(--text-muted);
  font-size: 10px;
  font-weight: 800;
  padding: 4px 10px;
  border-radius: 20px;
  white-space: nowrap;
}
.db-provider-free {
  font-size: 12px;
  color: var(--success);
  font-weight: 600;
  margin-bottom: 14px;
  padding: 8px 12px;
  background: rgba(46,213,115,0.05);
  border-radius: 8px;
}
.db-provider-actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
</style>

<script>
function activateProvider(provider) {
  if (!confirm('Ativar ' + provider + '? Isso vai migrar os dados automaticamente.')) return;
  fetch('/admin/database/activate/' + provider, { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        alert(data.message);
        location.reload();
      } else {
        alert('Erro: ' + data.message);
      }
    })
    .catch(err => alert('Erro: ' + err.message));
}
function migrateTo(provider) {
  if (!confirm('Migrar todos os dados para ' + provider + '?')) return;
  fetch('/admin/database/migrate-to/' + provider, { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      alert(data.success ? data.message : 'Erro: ' + data.message);
    })
    .catch(err => alert('Erro: ' + err.message));
}
</script>

</body>
</html>
