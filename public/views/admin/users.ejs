<!DOCTYPE html>
<html lang="pt-BR">
<head><%- include('../partials/head') %></head>
<body>
<div class="admin-layout">
<%- include('sidebar', { active: 'users' }) %>
<main class="admin-main" style="margin-left:0;padding:16px;padding-top:72px">
  <div class="admin-nav-mobile">
    <a href="/admin">Dashboard</a>
    <a href="/admin/animes">Animes</a>
    <a href="/admin/episodes">Episodios</a>
    <a href="/admin/users" class="active">Usuarios</a>
    <a href="/admin/settings">Config</a>
  </div>
  <div class="admin-header-mobile"><h1>Usuarios</h1></div>
  <div class="admin-card">
    <div class="admin-list">
      <% if (!users || !users.length) { %>
      <div class="admin-empty">Nenhum usuario.</div>
      <% } else { %>
      <% users.forEach(function(u) { %>
      <div class="admin-list-item">
        <img src="<%= u.avatar || '' %>" alt="" style="width:40px;height:40px;border-radius:50%">
        <div class="admin-list-item-info">
          <div class="admin-list-item-title"><%= u.name||'' %></div>
          <div class="admin-list-item-meta"><%= u.email||'' %> &bull; <%= u.role||'user' %></div>
        </div>
        <div class="admin-list-item-actions">
          <a href="/admin/users/promote/<%= u.id %>" class="btn btn-sm <%= u.role==='admin'?'btn-secondary':'btn-primary' %>"><%= u.role==='admin'?'Rebaixar':'Promover' %></a>
        </div>
      </div>
      <% }) %>
      <% } %>
    </div>
  </div>
</main>
</div>
</body>
</html>
