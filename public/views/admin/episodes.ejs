<!DOCTYPE html>
<html lang="pt-BR">
<head><%- include('../partials/head') %></head>
<body>
<div class="admin-layout">
<%- include('sidebar', { active: 'episodes' }) %>
<main class="admin-main" style="margin-left:0;padding:16px;padding-top:72px">
  <div class="admin-nav-mobile">
    <a href="/admin">Dashboard</a>
    <a href="/admin/animes">Animes</a>
    <a href="/admin/episodes" class="active">Episodios</a>
    <a href="/admin/users">Usuarios</a>
    <a href="/admin/settings">Config</a>
  </div>
  <div class="admin-header-mobile">
    <h1>Episodios</h1>
    <a href="/admin/episodes/new" class="btn btn-primary btn-sm">+ Novo</a>
  </div>
  <form method="GET" action="/admin/episodes" class="admin-search">
    <input type="text" name="q" value="<%= q || '' %>" placeholder="Buscar episodio ou anime...">
    <button type="submit" class="btn btn-primary btn-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
    </button>
  </form>
  <div class="admin-card">
    <div class="admin-list">
      <% if (!episodes || !episodes.length) { %>
      <div class="admin-empty">Nenhum episodio.<br><a href="/admin/episodes/new">Adicionar primeiro</a></div>
      <% } else { %>
      <% episodes.sort(function(a,b){return (b.number||0)-(a.number||0)}).forEach(function(ep) { var anime = animes?animes.find(function(x){return x.id===ep.animeId}):null; %>
      <div class="admin-list-item" onclick="location.href='/admin/episodes/edit/<%= ep.id %>'" style="cursor:pointer">
        <img src="<%= ep.thumbnail || (anime&&anime.cover) || '' %>" alt="">
        <div class="admin-list-item-info">
          <div class="admin-list-item-title">EP <%= ep.number||'?' %> - <%= ep.title||'' %></div>
          <div class="admin-list-item-meta"><%= anime?anime.title:'?' %></div>
        </div>
        <div class="admin-list-item-actions" onclick="event.stopPropagation()">
          <a href="/admin/episodes/edit/<%= ep.id %>" class="btn btn-sm btn-secondary">Editar</a>
          <a href="/admin/episodes/delete/<%= ep.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Excluir?')">Excluir</a>
        </div>
      </div>
      <% }) %>
      <% } %>
    </div>
  </div>
</main>
</div>
</body>
</html>
